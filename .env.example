# ──────────────────────────────────────────────────────────
#  Memorizr Worker — Environment Variables
# ──────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=memorizr
POSTGRES_PASSWORD=memorizr_secret
POSTGRES_DB=memorizr
POSTGRES_SSLMODE=disable

# Constructed DSN (used by the app):
DATABASE_URL=postgres://memorizr:memorizr_secret@postgres:5432/memorizr?sslmode=disable

# ── Connection Pool ──────────────────────────────────────
DB_POOL_MIN_CONNS=2
DB_POOL_MAX_CONNS=10

# ── Worker ───────────────────────────────────────────────
WORKER_POLL_INTERVAL=5s
WORKER_BATCH_SIZE=20
WORKER_PROCESS_TIMEOUT=3m
WORKER_STUCK_JOB_THRESHOLD=5m
